{
  "tasks": {
    "dev": "deno run -A server.ts",
    "build": "deno task build:client && deno task build:server",
    "build:client": "deno run -A npm:vite build --outDir dist/client",
    "build:server": "deno run -A npm:vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "NODE_ENV=production deno run -A server.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@std/http": "jsr:@std/http@^1.1.1",
    "vite": "npm:vite@^8.0.16",
    "hydro-js": "npm:hydro-js@^1.8.15",
    "hydro-js-integrations": "npm:hydro-js-integrations@^0.2.0",
    "happy-dom": "npm:happy-dom@^20.10.6",
    "jsdom": "npm:jsdom@^29.1.1"
  }
}
